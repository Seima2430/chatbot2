<Window x:Class="CybersecurityBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" Height="650" Width="900"
        Background="#1E1E2E" WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ASCII Logo Header -->
        <Border Grid.Row="0" Background="#2A2A3E" CornerRadius="8" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—       в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
                           FontFamily="Consolas" FontSize="7" Foreground="#00BFFF" HorizontalAlignment="Center"/>
                <TextBlock Text=" в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—      в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қ"
                           FontFamily="Consolas" FontSize="7" Foreground="#00BFFF" HorizontalAlignment="Center"/>
                <TextBlock Text=" в–Ҳв–Ҳв•‘      в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ      в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘"
                           FontFamily="Consolas" FontSize="7" Foreground="#00BFFF" HorizontalAlignment="Center"/>
                <TextBlock Text=" в–Ҳв–Ҳв•‘       в•ҡв–Ҳв–Ҳв•”в•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—      в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘"
                           FontFamily="Consolas" FontSize="7" Foreground="#00BFFF" HorizontalAlignment="Center"/>
                <TextBlock Text=" в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘      в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ   в–Ҳв–Ҳв•‘"
                           FontFamily="Consolas" FontSize="7" Foreground="#00BFFF" HorizontalAlignment="Center"/>
                <TextBlock Text="  в•ҡв•җв•җв•җв•җв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ      в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ    в•ҡв•җв•қ"
                           FontFamily="Consolas" FontSize="7" Foreground="#00BFFF" HorizontalAlignment="Center"/>
                <TextBlock Text="Cybersecurity Awareness Bot  |  Stay Safe Online"
                           FontFamily="Consolas" FontSize="12" Foreground="#FFD700"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Name input row -->
        <Border Grid.Row="1" Background="#2A2A3E" CornerRadius="8" Padding="10" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Your Name:" Foreground="#AAAACC" VerticalAlignment="Center"
                           FontFamily="Consolas" Margin="0,0,8,0"/>
                <TextBox x:Name="NameBox" Width="160" Background="#3A3A5E" Foreground="White"
                         FontFamily="Consolas" BorderBrush="#555577" Padding="4,2"
                         VerticalContentAlignment="Center"/>
                <Button x:Name="SetNameBtn" Content="Set Name" Margin="8,0,0,0"
                        Background="#4A90D9" Foreground="White" FontFamily="Consolas"
                        Padding="8,4" BorderThickness="0" Cursor="Hand"
                        Click="SetNameBtn_Click"/>
                <TextBlock x:Name="GreetingLabel" Text="" Foreground="#90EE90"
                           FontFamily="Consolas" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Chat display -->
        <Border Grid.Row="2" Background="#12121E" CornerRadius="8" Padding="6" Margin="0,0,0,8">
            <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto">
                <RichTextBox x:Name="ChatBox"
                             Background="Transparent" Foreground="White"
                             FontFamily="Consolas" FontSize="13"
                             IsReadOnly="True" BorderThickness="0"
                             Padding="6"/>
            </ScrollViewer>
        </Border>

        <!-- Input row -->
        <Border Grid.Row="3" Background="#2A2A3E" CornerRadius="8" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InputBox" Grid.Column="0"
                         Background="#3A3A5E" Foreground="White"
                         FontFamily="Consolas" FontSize="13"
                         BorderBrush="#555577" Padding="6,4"
                         VerticalContentAlignment="Center"
                         KeyDown="InputBox_KeyDown"
                         PlaceholderText="Type your message here..."/>
                <Button x:Name="SendBtn" Grid.Column="1" Content="Send"
                        Margin="8,0,0,0" Background="#4A90D9" Foreground="White"
                        FontFamily="Consolas" FontSize="13"
                        Padding="16,6" BorderThickness="0" Cursor="Hand"
                        Click="SendBtn_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
