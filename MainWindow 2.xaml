using System.Windows;
using System.Windows.Input;
using System.Windows.Documents;
using System.Windows.Media;

namespace CybersecurityBot
{
    public partial class MainWindow : Window
    {
        private ChatEngine engine = new ChatEngine();

        public MainWindow()
        {
            InitializeComponent();
            PlayVoiceGreeting();
            AppendBotMessage("Hello! Welcome to the Cybersecurity Awareness Bot.");
            AppendBotMessage("Enter your name above and click 'Set Name', then start chatting!");
        }

        private void PlayVoiceGreeting()
        {
            string file = "greeting.wav";
            if (System.IO.File.Exists(file))
            {
                try
                {
                    var player = new System.Media.SoundPlayer(file);
                    player.Play();
                }
                catch { }
            }
        }

        private void SetNameBtn_Click(object sender, RoutedEventArgs e)
        {
            string name = NameBox.Text.Trim();
            if (string.IsNullOrWhiteSpace(name))
                name = "Friend";

            engine.SetUserName(name);
            GreetingLabel.Text = $"Hi, {name}!";
            AppendBotMessage($"Nice to meet you, {name}! Ask me anything about cybersecurity.");
        }

        private void SendBtn_Click(object sender, RoutedEventArgs e)
        {
            HandleInput();
        }

        private void InputBox_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.Key == Key.Enter)
                HandleInput();
        }

        private void HandleInput()
        {
            string input = InputBox.Text.Trim();
            if (string.IsNullOrWhiteSpace(input)) return;

            AppendUserMessage(input);
            InputBox.Clear();

            string response = engine.GetResponse(input);
            AppendBotMessage(response);

            ChatScroll.ScrollToBottom();
        }

        private void AppendBotMessage(string text)
        {
            var para = new Paragraph();
            para.Inlines.Add(new Run("  Bot: ") { Foreground = Brushes.LightGreen });
            para.Inlines.Add(new Run(text) { Foreground = Brushes.White });
            para.Margin = new Thickness(0, 2, 0, 2);
            ChatBox.Document.Blocks.Add(para);
        }

        private void AppendUserMessage(string text)
        {
            string name = engine.UserName ?? "You";
            var para = new Paragraph();
            para.Inlines.Add(new Run($"  {name}: ") { Foreground = Brushes.Gold });
            para.Inlines.Add(new Run(text) { Foreground = Brushes.LightYellow });
            para.Margin = new Thickness(0, 2, 0, 2);
            ChatBox.Document.Blocks.Add(para);
        }
    }
}
